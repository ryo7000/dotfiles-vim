{
    "[rust][go][cpp][vue][python][proto][dart][nix]": {
      "coc.preferences.formatOnSave": true
    },
    "inlayHint.display": false,
    "diagnostic.warningSign": "! ",
    "snippets.userSnippetsDirectory": "~/.vim/UltiSnips",
    "go.goplsPath": "~/devel/go/bin/gopls",
    "go.goplsOptions": {
      "staticcheck": true,
      "gofumpt": true
    },
    "volar.disableFormatting": true,
    "languageserver": {
        "efm": {
            "command": "efm-langserver",
            "initializationOptions": {
                "documentFormatting": true,
                "documentRangeFormatting": true,
                "hover": true,
                "documentSymbol": true,
                "codeAction": true,
                "completion": true
            },
            "args": [],
            "filetypes": [
              "sh",
              "c",
              "cpp",
              "javascript",
              "javascriptreact",
              "typescript",
              "typescriptreact",
              "vue",
              "proto",
              "dockerfile"
            ]
        },
        "nix": {
            "command": "nixd",
            "filetypes": ["nix"],
            "rootPatterns": ["flake.nix", ".git"],
            "settings": {
                "nixd": {
                    "nixpkgs": {
                        "expr": "(import ./.nixd-options.nix).nixpkgs"
                    },
                    "formatting": {
                        "command": ["nixfmt"]
                    }
                },
                "options": {
                    "nixos": {
                        "expr": "(import ./.nixd-options.nix).nixos"
                    },
                    "home-manager": {
                        "expr": "(import ./.nixd-options.nix).home-manager"
                    }
                }
            }
        }
    }
}
